<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- ══ Header Row ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <!-- Stealth Toggle Button (bí mật) -->
        <TextView
            android:id="@+id/btnStealthToggle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="⌨"
            android:textSize="16sp"
            android:gravity="center"
            android:background="@drawable/bg_status"
            android:layout_marginEnd="8dp"
            android:textColor="@color/accent_cyan"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BOT NỐI TỪ"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"/>

        <!-- Mode Badge (chỉ hiện ở Bot mode) -->
        <TextView
            android:id="@+id/tvModeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯 CỰC PHẨM"
            android:textColor="@color/accent_green"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/badge_top"/>
    </LinearLayout>

    <!-- ══ Status Display ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_status"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_marginBottom="8dp">

        <View
            android:id="@+id/viewDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/accent_cyan"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hãy copy từ của đối thủ…"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:letterSpacing="0.03"
            android:singleLine="true"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- ══ BOT CONTROL VIEW (hiện mặc định) ══ -->
    <LinearLayout
        android:id="@+id/layoutBotControl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10"
        android:layout_marginBottom="2dp"
        android:visibility="visible">

        <Button
            android:id="@+id/btnMode"
            style="@style/Btn.Neon"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="4"
            android:layout_marginEnd="6dp"
            android:text="🎯  CỰC PHẨM"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnPause"
            style="@style/Btn.Muted"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="3"
            android:layout_marginEnd="6dp"
            android:text="⏸  Dừng"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnSwitch"
            style="@style/Btn.Accent"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="3"
            android:text="🌐  Đổi"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- ══ QWERTY KEYBOARD VIEW (ẩn mặc định) ══ -->
    <LinearLayout
        android:id="@+id/layoutQwerty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Hàng 1: q w e r t y u i o p -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <Button android:id="@+id/keyQ" style="@style/Key.Letter" android:text="q"/>
            <Button android:id="@+id/keyW" style="@style/Key.Letter" android:text="w"/>
            <Button android:id="@+id/keyE" style="@style/Key.Letter" android:text="e"/>
            <Button android:id="@+id/keyR" style="@style/Key.Letter" android:text="r"/>
            <Button android:id="@+id/keyT" style="@style/Key.Letter" android:text="t"/>
            <Button android:id="@+id/keyY" style="@style/Key.Letter" android:text="y"/>
            <Button android:id="@+id/keyU" style="@style/Key.Letter" android:text="u"/>
            <Button android:id="@+id/keyI" style="@style/Key.Letter" android:text="i"/>
            <Button android:id="@+id/keyO" style="@style/Key.Letter" android:text="o"/>
            <Button android:id="@+id/keyP" style="@style/Key.Letter" android:text="p"/>
        </LinearLayout>

        <!-- Hàng 2: a s d f g h j k l -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">
            <Button android:id="@+id/keyA" style="@style/Key.Letter" android:text="a"/>
            <Button android:id="@+id/keyS" style="@style/Key.Letter" android:text="s"/>
            <Button android:id="@+id/keyD" style="@style/Key.Letter" android:text="d"/>
            <Button android:id="@+id/keyF" style="@style/Key.Letter" android:text="f"/>
            <Button android:id="@+id/keyG" style="@style/Key.Letter" android:text="g"/>
            <Button android:id="@+id/keyH" style="@style/Key.Letter" android:text="h"/>
            <Button android:id="@+id/keyJ" style="@style/Key.Letter" android:text="j"/>
            <Button android:id="@+id/keyK" style="@style/Key.Letter" android:text="k"/>
            <Button android:id="@+id/keyL" style="@style/Key.Letter" android:text="l"/>
        </LinearLayout>

        <!-- Hàng 3: shift z x c v b n m del -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <Button android:id="@+id/keyShift" style="@style/Key.Action" android:layout_width="0dp" android:layout_weight="1.5" android:text="⇧"/>
            <Button android:id="@+id/keyZ" style="@style/Key.Letter" android:text="z"/>
            <Button android:id="@+id/keyX" style="@style/Key.Letter" android:text="x"/>
            <Button android:id="@+id/keyC" style="@style/Key.Letter" android:text="c"/>
            <Button android:id="@+id/keyV" style="@style/Key.Letter" android:text="v"/>
            <Button android:id="@+id/keyB" style="@style/Key.Letter" android:text="b"/>
            <Button android:id="@+id/keyN" style="@style/Key.Letter" android:text="n"/>
            <Button android:id="@+id/keyM" style="@style/Key.Letter" android:text="m"/>
            <Button android:id="@+id/keyDelete" style="@style/Key.Action" android:layout_width="0dp" android:layout_weight="1.5" android:text="⌫"/>
        </LinearLayout>

        <!-- Hàng 4: dấu cách, enter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal">
            <Button android:id="@+id/keyComma" style="@style/Key.Action" android:layout_width="0dp" android:layout_weight="1.5" android:text=","/>
            <Button android:id="@+id/keySpace" style="@style/Key.Space" android:layout_width="0dp" android:layout_weight="6" android:text="Khoảng trắng"/>
            <Button android:id="@+id/keyDot" style="@style/Key.Action" android:layout_width="0dp" android:layout_weight="1.5" android:text="."/>
            <Button android:id="@+id/keyEnter" style="@style/Key.Action" android:layout_width="0dp" android:layout_weight="2" android:text="↩"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
