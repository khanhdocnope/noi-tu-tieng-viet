<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- ══ Top Banner ══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@color/bg_surface">
        
        <!-- Glow Effect -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_banner_glow"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

        <!-- Decorative line top -->
        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:background="@color/accent_cyan"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BOT NỐI TỪ"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ Keyboard Edition"
            android:textColor="@color/accent_cyan"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:background="@color/accent_cyan"
            android:layout_marginTop="16dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ══ Setup Steps ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Step 1 Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="1"
                        android:textColor="@color/bg_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@color/accent_cyan"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Bật bàn phím trong cài đặt"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vào Cài đặt → Ngôn ngữ &amp; Bàn phím → Bật &quot;Bot Nối Từ Keyboard&quot;"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnEnableKeyboard"
                    style="@style/Btn.Neon"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="⚙  MỞ CÀI ĐẶT BÀN PHÍM"/>
            </LinearLayout>

            <!-- Step 2 Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="2"
                        android:textColor="@color/bg_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@color/accent_cyan"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Chọn Bot làm bàn phím mặc định"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nhấn nút bên dưới, sau đó chọn &quot;Bot Nối Từ Keyboard&quot; từ danh sách"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnSelectKeyboard"
                    style="@style/Btn.Accent"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="🌐  CHỌN BÀN PHÍM"/>
            </LinearLayout>

            <!-- How to use tip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Cách dùng"
                    android:textColor="@color/accent_cyan"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Khi chơi game, đổi sang bàn phím Bot\n2. Copy từ của đối thủ\n3. Bot tự điền đáp án — bạn chỉ cần nhấn Gửi!"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <!-- Test Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧪 KHU VỰC THỬ NGHIỆM"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    android:letterSpacing="0.05"/>

                <EditText
                    android:id="@+id/etTestArea"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_edittext_test"
                    android:gravity="top|start"
                    android:hint="Chạm vào đây để thử bàn phím...\n\n(Thử gõ hoặc dán một từ để xem Bot hoạt động thế nào)"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:padding="16dp"
                    android:inputType="textMultiLine"
                    android:scrollbars="vertical"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
