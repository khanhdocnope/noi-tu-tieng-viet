<?xml version="1.0" encoding="utf-8"?>
<!-- Dark card with rounded corners and subtle border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Border layer (simulated with a slightly lighter color) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1E2D47"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- Inner fill -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_card"/>
            <corners android:radius="15dp"/>
        </shape>
    </item>
</layer-list>
